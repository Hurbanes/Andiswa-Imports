<script>
/* ============================================================
   ⚙️  CONFIG  edit these, then re-share the file
   ============================================================ */
const CONFIG = {
  // Your WhatsApp number in international format, digits only (267 = Botswana).
  whatsapp: '8617784264090',          // China (+86) WhatsApp
  // Shown to visitors (pretty version):
  whatsappDisplay: '+86 177 8426 4090',
  callDisplay:     '+86 177 8426 4090',
  email:           'Andiswa.imports@gmail.com',

  // Estimator assumptions  all INDICATIVE. Update to your real figures.
  rates:    { USD: 13.6, CNY: 1.9 },   // Pula (BWP) per 1 unit of currency
  shipping: { air: 120, sea: 45 },     // Pula (BWP) per kg
  feePct:   0.10,                      // our fee = 10% of goods value…
  feeMin:   150                        // …or this minimum, whichever is higher
};

/* ---- apply config to the page ---- */
document.getElementById('waDisplay').textContent   = CONFIG.whatsappDisplay;
document.getElementById('callDisplay').textContent = CONFIG.callDisplay;
document.getElementById('emailDisplay').textContent= CONFIG.email;
document.getElementById('yr').textContent          = new Date().getFullYear();

const waBase = 'https://wa.me/' + CONFIG.whatsapp;
const waHello = waBase + '?text=' + encodeURIComponent("Hi Andiswa Imports! I'd like to ask about sourcing a product from China.");
['contactWa','cmWa','footWa','fab'].forEach(id=>{
  const el = document.getElementById(id);
  if(el) el.onclick = (e)=>{ e.preventDefault(); window.open(waHello,'_blank'); };
});
document.getElementById('cmCall').href  = 'tel:+' + CONFIG.whatsapp;
const mailHello = 'mailto:'+CONFIG.email+'?subject='+encodeURIComponent('Sourcing enquiry  Andiswa Imports')+'&body='+encodeURIComponent("Hi Andiswa Imports,\n\nI'd like to ask about sourcing the following from China:\n\n");
document.getElementById('cmEmail').href = mailHello;
document.getElementById('footEmail').onclick = (e)=>{ e.preventDefault(); window.location.href = mailHello; };

/* scholarship enquiry → WhatsApp with its own message */
const scholarWa = document.getElementById('scholarWa');
if(scholarWa){
  const scholarMsg = waBase + '?text=' + encodeURIComponent("Hi Andiswa Imports! I'd like to ask about studying in China  scholarships and how to apply.");
  scholarWa.onclick = (e)=>{ e.preventDefault(); window.open(scholarMsg,'_blank'); };
}

/* ============================================================
   header scroll state
   ============================================================ */
const hdr = document.getElementById('hdr');
const onScroll = ()=> hdr.classList.toggle('scrolled', window.scrollY > 24);
onScroll(); window.addEventListener('scroll', onScroll, {passive:true});

/* ============================================================
   mobile nav
   ============================================================ */
const navToggle = document.getElementById('navToggle');
const navLinks  = document.getElementById('navLinks');
const navScrim  = document.getElementById('navScrim');
function closeNav(){ navLinks.classList.remove('open'); navScrim.classList.remove('show'); navToggle.setAttribute('aria-expanded','false'); }
navToggle.onclick = ()=>{
  const open = navLinks.classList.toggle('open');
  navScrim.classList.toggle('show', open);
  navToggle.setAttribute('aria-expanded', open);
};
navScrim.onclick = closeNav;
navLinks.querySelectorAll('a').forEach(a=> a.addEventListener('click', closeNav));

/* ============================================================
   scroll reveal + step activation
   ============================================================ */
const io = new IntersectionObserver((entries)=>{
  entries.forEach(en=>{ if(en.isIntersecting){ en.target.classList.add('in'); io.unobserve(en.target); } });
},{threshold:.16, rootMargin:'0px 0px -8% 0px'});
document.querySelectorAll('.reveal, .step').forEach(el=> io.observe(el));

/* ============================================================
   recently-sourced ticker (illustrative examples)
   ============================================================ */
const sourced = [
  ['5kVA petrol generator','quoted'],
  ['300 LED bulbs','shipped'],
  ['iPhone 15 Pro · 2 units','delivered'],
  ['Salon hair-dryer chairs','sourced'],
  ['Hydraulic floor jack','quoted'],
  ['200 cotton t-shirts','shipped'],
  ['CCTV 4-camera kit','delivered'],
  ['Commercial blender','sourced'],
  ['Car brake pads · Toyota','quoted'],
  ['Bulk phone cases','shipped']
];
const tk = document.getElementById('ticker');
function buildTicker(){
  const make = ()=> sourced.map(([item,st])=>
    `<span class="ticker-item"><span class="dot">▸</span>${item}<span class="st">${st}</span></span>`).join('');
  tk.innerHTML = make() + make(); // duplicate for seamless loop
}
buildTicker();

/* ============================================================
   request form → WhatsApp / email
   ============================================================ */
let channel = 'WhatsApp';
const chBtns = document.querySelectorAll('.seg [data-ch]');
const contactLabel = document.getElementById('contactLabel');
const contactInput = document.getElementById('f-contact');
chBtns.forEach(b=> b.onclick = ()=>{
  channel = b.dataset.ch;
  chBtns.forEach(x=> x.setAttribute('aria-pressed', x===b));
  contactLabel.textContent = channel==='Email' ? 'Your email' : channel==='Call' ? 'Your phone number' : 'Your WhatsApp number';
  contactInput.type = channel==='Email' ? 'email' : 'text';
  contactInput.placeholder = channel==='Email' ? 'you@email.com' : '+267 …';
});

function val(id){ return document.getElementById(id).value.trim(); }
function buildRequestText(){
  const product = val('f-product') || '(not specified)';
  const qty     = val('f-qty')     || '1';
  const budget  = val('f-budget');
  const ref     = val('f-ref');
  const name    = val('f-name');
  const contact = val('f-contact');
  let t = "Hi Andiswa Imports! I'd like a quote.\n\n";
  t += "🔎 Product: " + product + "\n";
  t += "📦 Quantity: " + qty + "\n";
  if(budget)  t += "💰 Target budget: P" + budget + "\n";
  if(ref)     t += "🔗 Reference: " + ref + "\n";
  t += "\n";
  if(name)    t += "Name: " + name + "\n";
  t += "Preferred contact: " + channel + (contact ? " (" + contact + ")" : "") + "\n";
  return t;
}
function flashMsg(text){
  const m = document.getElementById('formMsg');
  m.textContent = text; m.classList.add('show');
  clearTimeout(flashMsg._t);
  flashMsg._t = setTimeout(()=> m.classList.remove('show'), 6000);
}
document.getElementById('sendWa').onclick = ()=>{
  if(!val('f-product')){ flashMsg('Add what you’re looking for first, then we can send it.'); document.getElementById('f-product').focus(); return; }
  window.open(waBase + '?text=' + encodeURIComponent(buildRequestText()), '_blank');
  flashMsg('Opening WhatsApp with your request  just press send.');
};
document.getElementById('sendEmail').onclick = ()=>{
  if(!val('f-product')){ flashMsg('Add what you’re looking for first, then we can send it.'); document.getElementById('f-product').focus(); return; }
  window.location.href = 'mailto:'+CONFIG.email
    +'?subject='+encodeURIComponent('Sourcing request  Andiswa Imports')
    +'&body='+encodeURIComponent(buildRequestText());
  flashMsg('Opening your email app with the request filled in.');
};

/* ============================================================
   estimator
   ============================================================ */
let curCur = 'USD', curShip = 'air';
const $ = id => document.getElementById(id);
function money(n){ return 'P ' + Math.round(n).toLocaleString('en-US'); }

document.querySelectorAll('.est-cur-seg [data-cur]').forEach(b=> b.onclick = ()=>{
  curCur = b.dataset.cur;
  document.querySelectorAll('.est-cur-seg [data-cur]').forEach(x=> x.setAttribute('aria-pressed', x===b));
  calcEst();
});
document.querySelectorAll('.est-ship-seg [data-ship]').forEach(b=> b.onclick = ()=>{
  curShip = b.dataset.ship;
  document.querySelectorAll('.est-ship-seg [data-ship]').forEach(x=> x.setAttribute('aria-pressed', x===b));
  $('estShipNote').textContent = curShip==='air' ? 'air freight' : 'sea freight';
  calcEst();
});

function calcEst(){
  const catMult = parseFloat($('e-cat').value) || 1;
  const cost    = Math.max(0, parseFloat($('e-cost').value)   || 0);
  const qty     = Math.max(1, parseInt($('e-qty').value)      || 1);
  const weight  = Math.max(0, parseFloat($('e-weight').value) || 0);

  const goods   = cost * CONFIG.rates[curCur] * qty;          // BWP
  const ship    = weight * qty * CONFIG.shipping[curShip];    // BWP
  let   fee     = goods * CONFIG.feePct * catMult;
  fee           = Math.max(fee, CONFIG.feeMin);
  const total   = goods + ship + fee;

  $('estGoods').textContent = money(goods);
  $('estShip').textContent  = money(ship);
  $('estFee').textContent   = money(fee);
  $('estGoodsNote').textContent = qty>1 ? '('+qty+' × '+cost+' '+curCur+')' : '';

  const el = $('estTotal');
  el.innerHTML = '<span class="cur">P</span>' + Math.round(total).toLocaleString('en-US');
  el.classList.remove('flash'); void el.offsetWidth; el.classList.add('flash');

  $('estSub').textContent = curShip==='air'
    ? 'Delivered to your door by air · roughly 1–2 weeks'
    : 'Delivered to your door by sea · roughly 5–8 weeks';
}
['e-cat','e-cost','e-qty','e-weight'].forEach(id=> $(id).addEventListener('input', calcEst));
calcEst();

/* ============================================================
   FAQ accordion
   ============================================================ */
document.querySelectorAll('.faq-item').forEach(item=>{
  const q = item.querySelector('.faq-q');
  const a = item.querySelector('.faq-a');
  q.addEventListener('click', ()=>{
    const open = item.classList.toggle('open');
    q.setAttribute('aria-expanded', open);
    a.style.maxHeight = open ? a.scrollHeight + 'px' : null;
  });
});
window.addEventListener('resize', ()=>{
  document.querySelectorAll('.faq-item.open .faq-a').forEach(a=> a.style.maxHeight = a.scrollHeight + 'px');
});

/* ============================================================
   reduced motion: freeze the parcel
   ============================================================ */
if(window.matchMedia('(prefers-reduced-motion: reduce)').matches){
  const svg = document.getElementById('routeSvg');
  try{ svg.pauseAnimations(); }catch(e){}
}
</script>
